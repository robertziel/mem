{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "allowJs": false,
    "resolveJsonModule": true
  },
  "include": [
    "App.tsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "e2e/**/*.ts",
    "index.ts",
    "playwright.config.ts",
    "scripts/**/*.mjs"
  ]
}
